# Copy to .env for local testing of the Slack drop. In CI these live in
# GitHub repo Settings: SLACK_WEBHOOK_URL as a secret, SITE_URL as a variable.

# Slack Incoming Webhook URL for the #channel that gets the daily standings.
SLACK_WEBHOOK_URL=

# Public URL of the deployed scoreboard (used for the "Open the table" button).
SITE_URL=https://slp-league.pages.dev
