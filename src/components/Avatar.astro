---
import { ramp } from '../lib/format.mjs';
interface Props {
  player: any;
  size?: number;
  radius?: number;
}
const { player, size = 46 } = Astro.props;
const r = ramp(player.color);
const w = size;
const h = Math.round(size * 1.12);
const fontSize = Math.round(size * 0.34);
const padBottom = Math.round(size * 0.2);
// A football-crest pennant: flat rounded top, point at the bottom.
const CREST = 'polygon(0% 0%, 100% 0%, 100% 58%, 50% 100%, 0% 58%)';
---
<div class="crest-av" style={`width:${w}px;height:${h}px;position:relative;flex:none;clip-path:${CREST}`}>
  <div class="crest-ini" style={`position:absolute;inset:0;background:${r.fill};color:#fff;font-size:${fontSize}px;padding-bottom:${padBottom}px`}>
    {player.initials}
  </div>
  {
    player.avatar && (
      <img
        src={`/img/${player.avatar}?v=${player.avatarV ?? 0}`}
        alt={player.nickname}
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
        onerror="this.style.display='none'"
      />
    )
  }
</div>
<style>
  .crest-ini { display: grid; place-items: center; font-family: var(--font-display); font-weight: 400; letter-spacing: 1px; }
</style>
