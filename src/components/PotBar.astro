---
import { ramp, money } from '../lib/format.mjs';
interface Props {
  state: any;
}
const { state } = Astro.props;
const total = state.pot;
const segs = state.players.map((p: any) => ({
  label: p.nickname,
  value: p.points,
  color: ramp(p.color).fill,
}));
segs.push({ label: 'Bank', value: state.bank, color: '#e7e3d2', bank: true });
---
<div class="pot card card-pad">
  <div class="pot-head">
    <div>
      <div class="eyebrow">The pot</div>
      <div class="pot-total display">{money(total)}</div>
    </div>
    <div class="pot-bank">
      <div class="pot-bank-num display">{money(state.bank)}</div>
      <div class="pot-bank-lbl">unclaimed in the bank</div>
    </div>
  </div>

  <div class="pot-bar" role="img" aria-label={`Pot split: ${segs.map((s: any) => `${s.label} ${money(s.value)}`).join(', ')}`}>
    {
      segs.map((s: any) => {
        const w = (s.value / total) * 100;
        return (
          <div class={`seg${s.bank ? ' bank' : ''}`} style={`width:${w}%;background:${s.color}`} title={`${s.label}: ${money(s.value)}`}>
            {s.bank && <span class="seg-lbl">Bank &middot; {money(s.value)}</span>}
          </div>
        );
      })
    }
  </div>

  <div class="pot-legend">
    {
      segs.map((s: any) => (
        <span class="leg">
          <span class="dot" style={`background:${s.color}`} aria-hidden="true" />
          <span class="leg-name">{s.label}</span>
          <span class="leg-val">{money(s.value)}</span>
        </span>
      ))
    }
  </div>
  <p class="pot-note">Every point a player claims is pulled out of the bank. Every penalty drops back in for the rest of the squad to grab.</p>
</div>
<style>
  .pot-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
  .pot-total { font-size: 52px; line-height: 0.9; color: var(--gold-2); }
  .pot-bank { text-align: right; }
  .pot-bank-num { font-size: 30px; line-height: 1; color: var(--ink); }
  .pot-bank-lbl { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .pot-bar { display: flex; height: 44px; border-radius: 12px; overflow: hidden; background: #e7e3d2; }
  .seg { min-width: 3px; box-shadow: inset -2px 0 0 rgba(255, 255, 255, 0.55); }
  .seg.bank { display: flex; align-items: center; padding: 0 16px; box-shadow: none; }
  .seg-lbl { font-weight: 700; font-size: 13px; color: var(--muted); white-space: nowrap; }
  .pot-legend { display: flex; flex-wrap: wrap; gap: 10px 22px; margin-top: 16px; }
  .leg { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; }
  .dot { width: 13px; height: 13px; border-radius: 4px; flex: none; }
  .leg-name { color: var(--muted); font-weight: 600; }
  .leg-val { font-weight: 800; font-variant-numeric: tabular-nums; }
  .pot-note { color: var(--muted); font-size: 14px; margin: 16px 0 0; line-height: 1.6; }
  @media (max-width: 520px) {
    .pot-total { font-size: 40px; }
    .pot-bank-num { font-size: 24px; }
    .pot-bar { height: 38px; }
  }
</style>
