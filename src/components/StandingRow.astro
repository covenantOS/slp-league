---
import { ramp, money, signed } from '../lib/format.mjs';
import Badge from './Badge.astro';
import Avatar from './Avatar.astro';
interface Props {
  p: any;
  pot: number;
}
const { p, pot } = Astro.props;
const r = ramp(p.color);
const share = Math.round((p.points / pot) * 100);
const leader = p.rank === 1;
const podium = ['', '#f2a51c', '#a8adb5', '#cd7f47'][p.rank] || '#c7ccd3';
const trendCls = p.last7 > 0 ? 'delta-up' : p.last7 < 0 ? 'delta-down' : 'delta-flat';
---
<a class={`row${leader ? ' leader' : ''}`} href={`/players/${p.id}/`} style={`--accent:${podium}`}>
  <div class="rank display">{p.rank}</div>
  <Avatar player={p} size={46} />
  <div class="who">
    <div class="who-top">
      <span class="name">{p.nickname}</span>
      {
        leader && (
          <span class="leadpill">
            <i class="ti ti-star-filled" aria-hidden="true" /> Leader
          </span>
        )
      }
      <span class="pill tier" style={`background:${r.soft};color:${r.mid};border-color:transparent`}>{p.tier.name}</span>
      {p.badges.slice(0, 2).map((b: string) => <Badge id={b} size="sm" />)}
    </div>
    <div class="who-sub">
      <span class={trendCls}>{p.last7 === 0 ? '— ' : ''}{signed(p.last7)}</span>
      <span class="dim">/ 7d active</span>
    </div>
  </div>
  <div class="score">
    <div class="dollars display">{money(p.dollars)}</div>
    <div class="share-bar"><span style={`width:${Math.max(share, 2)}%;background:${r.fill}`} /></div>
    <div class="share-txt">{share}% of pot</div>
  </div>
</a>
<style>
  .row {
    display: grid;
    grid-template-columns: 40px 46px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 16px 22px 16px 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 5px solid var(--accent);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.14s, box-shadow 0.14s;
  }
  .row + .row { margin-top: 12px; }
  .row:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .row.leader { background: linear-gradient(180deg, #fffae8, #fffdf6); border-color: rgba(242, 165, 28, 0.45); }
  .rank { font-size: 30px; color: var(--accent); text-align: center; line-height: 1; }
  .who { min-width: 0; }
  .who-top { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .name { font-family: var(--font-body); font-weight: 800; font-size: 21px; letter-spacing: -0.3px; }
  .leadpill { display: inline-flex; align-items: center; gap: 4px; background: var(--gold); color: var(--gold-ink); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; padding: 3px 9px; border-radius: var(--radius-pill); }
  .leadpill .ti { font-size: 12px; }
  .who-sub { display: flex; align-items: center; gap: 7px; margin-top: 5px; font-size: 13px; }
  .dim { color: var(--faint); }
  .score { text-align: right; min-width: 130px; }
  .dollars { font-size: 30px; line-height: 1; color: var(--ink); }
  .share-bar { height: 5px; border-radius: 999px; background: var(--bg-2); margin: 8px 0 4px; overflow: hidden; }
  .share-bar span { display: block; height: 100%; border-radius: 999px; }
  .share-txt { font-size: 11px; color: var(--faint); font-weight: 600; }
  @media (max-width: 540px) {
    .row { grid-template-columns: 28px 42px 1fr auto; gap: 11px; padding: 13px 14px 13px 12px; }
    .name { font-size: 18px; }
    .dollars { font-size: 24px; }
    .score { min-width: 96px; }
    .rank { font-size: 24px; }
  }
</style>
