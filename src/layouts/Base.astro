---
import '../styles/global.css';
import config from '../data/config.json';
import { getGame } from '../lib/league.mjs';

interface Props {
  title?: string;
  description?: string;
  active?: 'standings' | 'players' | 'history' | 'seasons' | 'rules';
}
const { title, description, active } = Astro.props;
const league = config.league;
const pageTitle = title ? `${title} | ${league.name}` : `${league.name} — ${league.tagline}`;
const desc = description ?? league.tagline;
const season = (await getGame(Astro.locals?.runtime?.env)).season;
const persistent = !!(Astro.locals?.runtime?.env?.LEAGUE);

const nav = [
  { key: 'standings', href: '/', label: 'Standings', icon: 'trophy' },
  { key: 'players', href: '/players/', label: 'Players', icon: 'users' },
  { key: 'history', href: '/history/', label: 'History', icon: 'history' },
  { key: 'seasons', href: '/seasons/', label: 'Seasons', icon: 'archive' },
  { key: 'rules', href: '/rules/', label: 'How it works', icon: 'help-circle' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0f1a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css"
    />
  </head>
  <body>
    {
      !persistent && (
        <div class="warnbar">
          Changes are not being saved. This is normal in local preview; on Cloudflare, bind a KV namespace named <b>LEAGUE</b> to this Pages project and redeploy.
        </div>
      )
    }
    <header class="masthead">
      <div class="wrap">
        <a class="brand" href="/">
          <span class="crest" aria-hidden="true"><i class="ti ti-ball-football"></i></span>
          <span>{league.name}</span>
        </a>
        <nav class="nav" aria-label="Primary">
          {
            nav.map((n) => (
              <a href={n.href} class={active === n.key ? 'active' : ''} aria-current={active === n.key ? 'page' : undefined}>
                <i class={`ti ti-${n.icon}`} aria-hidden="true" />
                <span>{n.label}</span>
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="wrap" style="padding-top: 26px;">
      <slot />
    </main>

    <footer class="foot">
      <div class="wrap">
        <span>{season.name} &middot; 1 point = $1 &middot; ${season.potUSD.toLocaleString('en-US')} shared pot</span>
        <span>Built by <a href="https://servicelinepro.com">{league.builtBy}</a></span>
      </div>
    </footer>
  </body>
</html>
