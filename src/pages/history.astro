---
import Base from '../layouts/Base.astro';
import { activityFeed, data } from '../lib/league.mjs';
import { ramp, signed, shortDate } from '../lib/format.mjs';
import config from '../data/config.json';

const feed = activityFeed(data);
const rubric = Object.fromEntries(config.rubric.map((c) => [c.key, c])) as Record<string, any>;

type Group = { date: string; items: any[] };
const groups: Group[] = [];
for (const e of feed) {
  const g = groups[groups.length - 1];
  if (g && g.date === e.date) g.items.push(e);
  else groups.push({ date: e.date, items: [e] });
}
---

<Base title="History" active="history">
  <section class="hero">
    <div class="eyebrow">Every point, logged in the open</div>
    <h1>History</h1>
  </section>

  {
    groups.map((g) => (
      <section class="daygroup">
        <div class="dayhead">{shortDate(g.date)}</div>
        <div class="card feed-list">
          {g.items.map((e: any, i: number) => {
            const meta = rubric[e.category] || { label: e.category, icon: 'point' };
            const r = ramp(e.player.color);
            return (
              <div class={`feed${i > 0 ? ' br' : ''}`}>
                <div class="favatar" style={`background:${r.fill};color:${r.ink}`}>
                  {e.player.initials}
                </div>
                <div class="feed-main">
                  <div class="feed-reason">{e.reason}</div>
                  <div class="feed-sub">
                    {e.player.nickname} &middot; {meta.label}
                  </div>
                </div>
                <div class={`feed-pts ${e.points >= 0 ? 'pos' : 'neg'}`}>{signed(e.points)}</div>
              </div>
            );
          })}
        </div>
      </section>
    ))
  }
</Base>

<style>
  .hero { padding: 8px 0 6px; }
  .hero h1 { margin-top: 6px; }
  .daygroup { margin-top: 22px; }
  .dayhead { font-family: var(--font-display); text-transform: uppercase; letter-spacing: 1.4px; font-size: 12px; color: var(--muted); margin-bottom: 9px; padding-left: 4px; }
  .feed-list { overflow: hidden; }
  .feed { display: flex; align-items: center; gap: 13px; padding: 13px 18px; }
  .feed.br { border-top: 1px solid var(--line); }
  .favatar { width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center; font-family: var(--font-display); font-weight: 600; font-size: 13px; flex: none; }
  .feed-main { flex: 1; min-width: 0; }
  .feed-reason { font-size: 14px; }
  .feed-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }
  .feed-pts { font-family: var(--font-display); font-weight: 600; font-size: 18px; font-variant-numeric: tabular-nums; }
  .feed-pts.pos { color: var(--pitch); }
  .feed-pts.neg { color: var(--red); }
</style>
