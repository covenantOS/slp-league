---
import Base from '../layouts/Base.astro';
import PotBar from '../components/PotBar.astro';
import StandingRow from '../components/StandingRow.astro';
import Avatar from '../components/Avatar.astro';
import { getGame, computeState, activityFeed } from '../lib/league.mjs';
import { money, signed, shortDate, ramp } from '../lib/format.mjs';
import config from '../data/config.json';

const game = await getGame(Astro.locals?.runtime?.env);
const state = computeState(game);
const leader = state.players[0];
const recent = activityFeed(game, 5);
const ch = game.config.challenge;
const seasonPct = Math.round(state.seasonProgress * 100);
---

<Base active="standings">
  <section class="hero">
    <div class="eyebrow">{config.league.tagline}</div>
    <h1>Standings</h1>
    <div class="hero-meta">
      <span><i class="ti ti-calendar-event" aria-hidden="true"></i> {state.daysLeft} days left in {game.season.name}</span>
      <span class="sep">&middot;</span>
      <span><i class="ti ti-crown" style="color:var(--gold)" aria-hidden="true"></i> {leader.nickname} leads with {money(leader.dollars)}</span>
    </div>
    <div class="season-meter" title={`${seasonPct}% of the season played`}><span style={`width:${seasonPct}%`}></span></div>
  </section>

  <PotBar state={state} />

  <section class="section">
    <div class="section-head">
      <h2>The table</h2>
      <span class="link">{state.players.length} players &middot; winner takes the most</span>
    </div>
    {state.players.map((p: any) => <StandingRow p={p} pot={state.pot} />)}
  </section>

  <section class="section">
    <div class="card card-pad challenge">
      <div class="ch-ico"><i class="ti ti-target-arrow" aria-hidden="true"></i></div>
      <div class="ch-body">
        <div class="eyebrow">{ch.title}</div>
        <div class="ch-desc">{ch.desc}</div>
      </div>
      <span class="chip gold">Bonus points</span>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Latest</h2>
      <a class="link" href="/history/">Full history &rarr;</a>
    </div>
    <div class="card feed-list">
      {
        recent.map((e: any, i: number) => (
          <div class={`feed${i > 0 ? ' br' : ''}`}>
            <Avatar player={e.player} size={34} radius={9} />
            <div class="feed-main">
              <div class="feed-reason">{e.reason}</div>
              <div class="feed-sub">
                {e.player.nickname} &middot; {shortDate(e.date)}
              </div>
            </div>
            <div class={`feed-pts ${e.points >= 0 ? 'pos' : 'neg'}`}>{signed(e.points)}</div>
          </div>
        ))
      }
    </div>
  </section>
</Base>

<script is:inline>
  (function () {
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    try {
      if (sessionStorage.getItem('slp_confetti')) return;
      sessionStorage.setItem('slp_confetti', '1');
    } catch (e) {}
    var colors = ['#f6b400', '#20c45f', '#4f9dec', '#f07a52'];
    var canvas = document.createElement('canvas');
    canvas.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:999';
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    document.body.appendChild(canvas);
    var ctx = canvas.getContext('2d');
    var parts = [];
    for (var i = 0; i < 40; i++) {
      parts.push({
        x: window.innerWidth / 2 + (Math.random() - 0.5) * 140,
        y: window.innerHeight * 0.26,
        vx: (Math.random() - 0.5) * 7,
        vy: Math.random() * -7 - 3,
        r: 4 + Math.random() * 5,
        col: colors[i % colors.length],
        rot: Math.random() * 6,
      });
    }
    var start = performance.now();
    function frame(t) {
      var dt = t - start;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var k = 0; k < parts.length; k++) {
        var p = parts[k];
        p.vy += 0.2;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += 0.2;
        ctx.save();
        ctx.globalAlpha = Math.max(0, 1 - dt / 1700);
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.fillStyle = p.col;
        ctx.fillRect(-p.r / 2, -p.r / 2, p.r, p.r * 0.6);
        ctx.restore();
      }
      if (dt < 1800) requestAnimationFrame(frame);
      else canvas.remove();
    }
    requestAnimationFrame(frame);
  })();
</script>

<style>
  .hero { padding: 8px 0 22px; }
  .hero h1 { margin: 6px 0 12px; }
  .hero-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; color: var(--muted); font-size: 14px; }
  .hero-meta .ti { font-size: 16px; vertical-align: -2px; }
  .hero-meta .sep { color: var(--faint); }
  .season-meter { height: 5px; border-radius: 999px; background: var(--surface-2); margin-top: 16px; overflow: hidden; }
  .season-meter span { display: block; height: 100%; background: var(--pitch); border-radius: 999px; }

  .challenge { display: flex; align-items: center; gap: 16px; }
  .ch-ico { width: 44px; height: 44px; border-radius: 12px; background: rgba(32, 196, 95, 0.14); color: var(--pitch); display: grid; place-items: center; font-size: 24px; flex: none; }
  .ch-body { flex: 1; min-width: 0; }
  .ch-desc { font-size: 15px; margin-top: 2px; }

  .feed-list { overflow: hidden; }
  .feed { display: flex; align-items: center; gap: 13px; padding: 13px 18px; }
  .feed.br { border-top: 1px solid var(--line); }  .feed-main { flex: 1; min-width: 0; }
  .feed-reason { font-size: 14px; }
  .feed-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }
  .feed-pts { font-family: var(--font-display); font-weight: 600; font-size: 18px; font-variant-numeric: tabular-nums; }
  .feed-pts.pos { color: var(--pitch); }
  .feed-pts.neg { color: var(--red); }
</style>
